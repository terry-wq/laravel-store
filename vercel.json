{
  "version": 2,

  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.8.0",
      "config": {
        "includeFiles": [
          "public/**"
        ]
      }
    }
  ],

  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },

    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },

    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|webp))",
      "dest": "/public/$1"
    },

    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ],

  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://laravel-store-kappa.vercel.app",

    "SESSION_DRIVER": "cookie",

    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",

    "VIEW_COMPILED_PATH": "/tmp/views"
  }
}
